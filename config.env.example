# ─────────────────────────────────────────────────────────────────────────────
# money-app-infra / config.env
# Copy to config.env and fill in your values:
#   cp config.env.example config.env
# config.env is gitignored — it stays on your machine only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Proxmox host (the node itself, not a VM) ──────────────────────────────
PROXMOX_HOST=192.168.1.10       # IP of your Proxmox node
PROXMOX_USER=root               # Usually root
PROXMOX_SSH_KEY=~/.ssh/id_rsa   # SSH key — leave blank to use ssh-agent default

# ── LXC container settings ────────────────────────────────────────────────
CT_ID=200                       # Container ID — pick any unused number (check in UI)
CT_HOSTNAME=money-app           # Hostname shown in Proxmox UI
CT_STORAGE=local-lvm            # Storage for rootfs (check yours in UI: Datacenter → Storage)
CT_BRIDGE=vmbr0                 # Network bridge (almost always vmbr0)
CT_CORES=2
CT_MEMORY=512                   # RAM in MB (512 is plenty for a static site)

# ── Networking ────────────────────────────────────────────────────────────
# Use 'dhcp' to get an IP automatically, or set a static IP like '192.168.1.200/24'
CT_IP=dhcp
CT_GW=192.168.1.1               # Gateway — only needed when CT_IP is static

# ── App ───────────────────────────────────────────────────────────────────
APP_REPO=https://github.com/feedmittens/money-app.git
APP_PORT=8080                   # Port you'll visit in the browser (ignored when DOMAIN is set)

# ── SSL / Let's Encrypt (optional) ────────────────────────────────────────
# Requires: a domain pointing at this server's public IP, and ports 80+443
# forwarded from your router to the container IP.
# Leave DOMAIN blank to skip SSL and use plain HTTP on APP_PORT instead.
DOMAIN=                         # e.g. money.example.com
CERTBOT_EMAIL=                  # e.g. you@example.com

