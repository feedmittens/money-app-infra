# ─────────────────────────────────────────────────────────────────────────────
# money-app-infra / config.env
# Copy to config.env and fill in your values:
#   cp config.env.example config.env
# config.env is gitignored — it stays on your machine only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Proxmox host (the node itself, not a VM) ──────────────────────────────
PROXMOX_HOST=192.168.1.10       # IP of your Proxmox node
PROXMOX_USER=root               # Usually root
PROXMOX_SSH_KEY=~/.ssh/id_rsa   # SSH key — leave blank to use ssh-agent default

# ── LXC container settings ────────────────────────────────────────────────
CT_ID=200                       # Container ID — pick any unused number (check in UI)
CT_HOSTNAME=money-app           # Hostname shown in Proxmox UI
CT_STORAGE=local-lvm            # Storage for rootfs (check yours in UI: Datacenter → Storage)
CT_BRIDGE=vmbr0                 # Network bridge (almost always vmbr0)
CT_CORES=2
CT_MEMORY=1024                  # RAM in MB (1 GB — needed for Node.js + build)

# ── Networking ────────────────────────────────────────────────────────────
# Use 'dhcp' to get an IP automatically, or set a static IP like '192.168.1.200/24'
CT_IP=dhcp
CT_GW=192.168.1.1               # Gateway — only needed when CT_IP is static

# ── App ───────────────────────────────────────────────────────────────────
APP_REPO=https://github.com/feedmittens/money-app.git
APP_PORT=8080                   # Port you'll visit in the browser (ignored when DOMAIN is set)

# ── SSL ───────────────────────────────────────────────────────────────────
# SSL_MODE controls how HTTPS is configured:
#
#   selfsigned   (default) — generates a self-signed cert with OpenSSL.
#                Works on any network including air-gapped / internal servers.
#                Your browser will show a one-time security warning; you can
#                dismiss it or add the cert to your OS/browser trust store.
#
#   letsencrypt  — obtains a free trusted cert from Let's Encrypt.
#                Requires a public domain, internet access from the container,
#                and ports 80+443 forwarded from your router to the container.
#
#   none         — plain HTTP on APP_PORT. No HTTPS.
#
SSL_MODE=selfsigned

# Required for letsencrypt only:
DOMAIN=                         # e.g. money.example.com
CERTBOT_EMAIL=                  # e.g. you@example.com

# ── Auth & Database ───────────────────────────────────────────────────────────
# These are injected into the container during setup and written to server/.env
# (which is gitignored and never leaves the server).

ADMIN_EMAIL=                    # Your email — this account is auto-approved as admin on first register
DB_PASSWORD=                    # PostgreSQL password for the 'bvmoney' user (generate a strong one)
SESSION_SECRET=                 # Random secret for session signing (leave blank to auto-generate)
APP_URL=                        # Full base URL e.g. https://money.yourdomain.com (needed for Google OAuth)

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Leave blank to disable Google sign-in. To enable:
# 1. Create a project at console.cloud.google.com
# 2. Enable the Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorised redirect URI: <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

