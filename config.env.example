# ─────────────────────────────────────────────────────────────────────────────
# money-app-infra / config.env
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
# config.env is gitignored and stays on your machine only.
# ─────────────────────────────────────────────────────────────────────────────

# Proxmox VM running Docker (SSH target)
VM_HOST=192.168.1.100          # IP or hostname of your Docker VM
VM_USER=root                   # SSH user (or a deploy user with docker access)
VM_SSH_KEY=~/.ssh/id_rsa       # SSH key path (leave blank to use default)

# App source
APP_REPO=https://github.com/feedmittens/money-app.git
APP_DIR=/opt/money-app         # Where to clone on the VM

# Nginx
APP_PORT=8080                  # Host port — access via http://VM_HOST:APP_PORT
