# PostgreSQL Configuration
DB_PASSWORD=changeme

# Node.js Environment
NODE_ENV=production

# Application Configuration
APP_PORT=8080
APP_REPO=https://github.com/feedmittens/money-app.git

# SSL/TLS Configuration
# Options: selfsigned, letsencrypt, none
SSL_MODE=selfsigned
DOMAIN=localhost
CERTBOT_EMAIL=

# Application URLs and OAuth
APP_URL=http://localhost:8080
ADMIN_EMAIL=admin@example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session Management
SESSION_SECRET=
